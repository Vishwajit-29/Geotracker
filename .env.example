# ============================================
# GeoTracker - Environment Variables
# ============================================
# Copy this file to .env and update the values
# Usage: docker compose --env-file .env up -d
# ============================================

# ---------- PostgreSQL ----------
POSTGRES_DB=geotracker
POSTGRES_USER=geotracker
POSTGRES_PASSWORD=geotracker

# ---------- Spring Boot Datasource ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/geotracker
SPRING_DATASOURCE_USERNAME=geotracker
SPRING_DATASOURCE_PASSWORD=geotracker

# ---------- Redis ----------
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ---------- JWT ----------
JWT_SECRET=change-me-to-a-strong-random-256-bit-secret-key-in-production
JWT_EXPIRATION=86400000

# ---------- Gemini API (for frontend build) ----------
GEMINI_API_KEY=
